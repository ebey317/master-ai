{
  "manifest_version": 3,
  "name": "Sensei — browser limb",
  "short_name": "Sensei",
  "description": "Sensei's reach into the browser — her arm on the page, not a separate tool. Part of the Master AI local-first agent stack.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8080/*",
    "http://localhost:8080/*",
    "http://*/*",
    "https://*/*",
    "file:///*"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Sensei"
  },
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "options_page": "options.html"
}
