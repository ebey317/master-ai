<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>🥷 Master AI</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/core.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/python.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/javascript.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/bash.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/css.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/lib/languages/json.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/styles/github-dark.min.css"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#212121;--bg2:#2f2f2f;--bg3:#3a3a3a;--bg4:#424242;
  --border:#444;--border2:#555;
  --text:#ececec;--text2:#aaa;--text3:#777;
  --accent:#cc785c;--accent2:#e8a87c;
  --user-bg:#2f2f2f;--ai-bg:transparent;
  --input-bg:#2f2f2f;--input-border:#555;
  --success:#4caf50;--error:#f44336;--warn:#ff9800;
  --shadow:0 2px 12px rgba(0,0,0,0.4);
  --radius:12px;--radius-sm:8px;--radius-xs:6px;
}
[data-theme="light"]{
  --bg:#f8f8f7;--bg2:#f0eeeb;--bg3:#e8e5e0;--bg4:#ddd9d3;
  --border:#ddd;--border2:#ccc;
  --text:#1a1a1a;--text2:#555;--text3:#999;
  --accent:#cc785c;--accent2:#b5622a;
  --user-bg:#e8e5e0;--ai-bg:transparent;
  --input-bg:#fff;--input-border:#ccc;
  --shadow:0 2px 12px rgba(0,0,0,0.1);
}
[data-theme="ocean"]{
  --bg:#0d1b2a;--bg2:#1b2d3e;--bg3:#243b52;--bg4:#2e4a63;
  --border:#2a4a6b;--border2:#3a6a8a;
  --text:#d0e8f5;--text2:#7db8d8;--text3:#4a8aaa;
  --accent:#00b4d8;--accent2:#48cae4;
  --user-bg:#1b2d3e;--ai-bg:transparent;
  --input-bg:#1b2d3e;--input-border:#2a4a6b;
  --shadow:0 2px 12px rgba(0,0,0,0.5);
}
[data-theme="midnight"]{
  --bg:#0a0a12;--bg2:#12121f;--bg3:#1a1a2e;--bg4:#22223a;
  --border:#2a2a45;--border2:#3a3a60;
  --text:#e0d8f8;--text2:#9080d0;--text3:#5040a0;
  --accent:#7c6fcd;--accent2:#a89ae8;
  --user-bg:#12121f;--ai-bg:transparent;
  --input-bg:#12121f;--input-border:#2a2a45;
  --shadow:0 2px 12px rgba(0,0,0,0.7);
}
[data-theme="sunkissed"]{
  --bg:#1a1008;--bg2:#261808;--bg3:#33210a;--bg4:#40280c;
  --border:#5a3a10;--border2:#7a5020;
  --text:#fdebc8;--text2:#d4a055;--text3:#8a6030;
  --accent:#f5a623;--accent2:#ffc85a;
  --user-bg:#261808;--ai-bg:transparent;
  --input-bg:#261808;--input-border:#5a3a10;
  --shadow:0 2px 12px rgba(0,0,0,0.6);
}
html,body{height:100%;font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:15px;line-height:1.6}
body{display:flex;height:100vh;overflow:hidden}

/* ── SIDEBAR ── */
.sidebar{width:260px;min-width:260px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;transition:width 0.2s;overflow:hidden}
.sidebar.collapsed{width:0;min-width:0}
.sidebar-header{padding:16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.new-chat-btn{flex:1;padding:8px 14px;background:var(--accent);color:#fff;border:none;border-radius:var(--radius-sm);font-size:13px;font-weight:500;cursor:pointer;font-family:inherit}
.new-chat-btn:hover{opacity:0.9}
.sidebar-toggle{width:32px;height:32px;border:1px solid var(--border2);background:transparent;color:var(--text2);border-radius:var(--radius-xs);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center}
.sidebar-toggle:hover{background:var(--bg3)}
.sessions-list{flex:1;overflow-y:auto;padding:8px}
.session-item{padding:6px 10px;border-radius:var(--radius-xs);cursor:pointer;font-size:13px;color:var(--text2);margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.session-item:hover{background:var(--bg3);color:var(--text)}
.session-item.active{background:var(--bg3);color:var(--text)}
.session-source{font-size:10px;color:var(--text3);display:block;margin-top:1px}
.session-rename-input{width:100%;background:var(--bg3);border:1px solid var(--accent);border-radius:3px;color:var(--text);font-size:13px;padding:2px 4px;font-family:inherit;outline:none}
.sidebar-footer{padding:12px;border-top:1px solid var(--border)}
.settings-btn{width:100%;padding:8px;background:transparent;border:1px solid var(--border);color:var(--text2);border-radius:var(--radius-xs);cursor:pointer;font-size:13px;font-family:inherit}
.settings-btn:hover{background:var(--bg3)}

/* ── MAIN ── */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;position:relative}

/* ── HEADER ── */
.header{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;background:var(--bg);z-index:10;flex-wrap:wrap;gap:8px}
.sidebar-open-btn{width:32px;height:32px;border:1px solid var(--border);background:transparent;color:var(--text2);border-radius:var(--radius-xs);cursor:pointer;font-size:16px;display:none;align-items:center;justify-content:center}
.sidebar-open-btn:hover{background:var(--bg3)}
.model-select{padding:6px 10px;background:var(--bg2);border:1px solid var(--border);color:var(--text);border-radius:var(--radius-xs);font-size:13px;font-family:inherit;cursor:pointer;min-width:150px}
.model-select:focus{outline:none;border-color:var(--accent)}
.header-spacer{flex:1}
.toggles{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.toggle-btn{display:flex;align-items:center;gap:5px;padding:5px 10px;border:1px solid var(--border);background:transparent;color:var(--text2);border-radius:20px;font-size:12px;cursor:pointer;font-family:inherit;transition:all 0.15s;white-space:nowrap}
.toggle-btn.on{background:var(--bg3);border-color:var(--accent);color:var(--text)}
.toggle-btn:hover{border-color:var(--border2);color:var(--text)}
.toggle-dot{width:7px;height:7px;border-radius:50%;background:var(--text3)}
.toggle-btn.on .toggle-dot{background:var(--accent)}
.theme-dots{display:flex;align-items:center;gap:6px}
.theme-dot{width:20px;height:20px;border-radius:50%;border:2px solid transparent;cursor:pointer;transition:transform 0.15s,border-color 0.15s;padding:0}
.theme-dot:hover{transform:scale(1.2)}
.theme-dot.active{border-color:#fff;transform:scale(1.15)}

/* ── CHAT AREA ── */
.chat-area{flex:1;overflow-y:auto;padding:24px 0;scroll-behavior:smooth}
.chat-area::-webkit-scrollbar{width:6px}
.chat-area::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px}
.messages-wrap{max-width:720px;margin:0 auto;padding:0 20px;display:flex;flex-direction:column;gap:4px}

/* empty state */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:16px;padding:40px 20px;text-align:center}
.empty-state h1{font-size:26px;font-weight:500;color:var(--text)}
.empty-state p{font-size:14px;color:var(--text2);max-width:420px}
.suggestion-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px;width:100%;max-width:500px}
.suggestion{padding:12px 14px;border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;font-size:13px;color:var(--text2);text-align:left;background:transparent;transition:all 0.15s;font-family:inherit}
.suggestion:hover{background:var(--bg2);border-color:var(--border2);color:var(--text)}

/* ── MESSAGES ── */
.msg{display:flex;gap:12px;padding:8px 0;animation:fadeIn 0.2s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.msg.user{flex-direction:row-reverse}
.msg-avatar{width:32px;height:32px;min-width:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;margin-top:2px}
.msg.ai .msg-avatar{background:var(--accent);color:#fff}
.msg.user .msg-avatar{background:var(--bg3);color:var(--text2)}
.msg-body{flex:1;max-width:88%}
.msg.user .msg-body{display:flex;justify-content:flex-end}
.msg-bubble{padding:12px 16px;border-radius:var(--radius);font-size:14.5px;line-height:1.7;word-break:break-word}
.msg.ai .msg-bubble{background:var(--ai-bg);padding-left:0;border-radius:0}
.msg.user .msg-bubble{background:var(--user-bg);border-radius:var(--radius)}
.msg.user .msg-bubble{max-width:85%}
.msg-actions{display:flex;gap:6px;margin-top:6px;opacity:0;transition:opacity 0.15s}
.msg:hover .msg-actions{opacity:1}
.msg-action-btn{padding:3px 8px;border:1px solid var(--border);background:transparent;color:var(--text3);border-radius:4px;font-size:11px;cursor:pointer;font-family:inherit}
.msg-action-btn:hover{background:var(--bg3);color:var(--text2)}
.thinking-dot{display:inline-block;width:7px;height:7px;background:var(--accent);border-radius:50%;animation:wave 1.1s ease-in-out infinite;margin:0 2px}
.thinking-dot:nth-child(2){animation-delay:0.15s}
.thinking-dot:nth-child(3){animation-delay:0.30s}
@keyframes wave{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}
.queue-badge{display:inline-block;background:#b8860b;color:#fff;font-size:10px;border-radius:8px;padding:1px 5px;margin-left:4px;vertical-align:middle}
.route-tag{display:inline-block;font-size:10px;color:var(--text3);padding:2px 6px;border:1px solid var(--border);border-radius:10px;margin-bottom:6px}

/* markdown */
.msg-bubble h1,.msg-bubble h2,.msg-bubble h3{margin:12px 0 6px;font-weight:600;line-height:1.3}
.msg-bubble h1{font-size:18px}.msg-bubble h2{font-size:16px}.msg-bubble h3{font-size:14.5px}
.msg-bubble p{margin-bottom:10px}.msg-bubble p:last-child{margin-bottom:0}
.msg-bubble ul,.msg-bubble ol{margin:6px 0 10px 20px}
.msg-bubble li{margin-bottom:3px}
.msg-bubble a{color:var(--accent2);text-decoration:none}.msg-bubble a:hover{text-decoration:underline}
.msg-bubble strong{font-weight:600}
.msg-bubble em{font-style:italic}
.msg-bubble blockquote{border-left:3px solid var(--border2);padding-left:12px;color:var(--text2);margin:8px 0}
.msg-bubble hr{border:none;border-top:1px solid var(--border);margin:12px 0}
.msg-bubble table{border-collapse:collapse;width:100%;margin:8px 0;font-size:13px}
.msg-bubble th,.msg-bubble td{border:1px solid var(--border);padding:6px 10px;text-align:left}
.msg-bubble th{background:var(--bg2)}
.code-block{position:relative;margin:10px 0}
.code-lang{position:absolute;top:8px;left:14px;font-size:11px;color:var(--text3);font-family:monospace;text-transform:lowercase}
.code-copy{position:absolute;top:6px;right:8px;padding:3px 8px;border:1px solid var(--border2);background:var(--bg3);color:var(--text2);border-radius:4px;font-size:11px;cursor:pointer;font-family:inherit;opacity:0;transition:opacity 0.15s}
.code-block:hover .code-copy{opacity:1}
.msg-bubble pre{background:#1e1e1e;border-radius:var(--radius-sm);padding:36px 14px 14px;overflow-x:auto;font-size:13px}
[data-theme="light"] .msg-bubble pre{background:#1e1e1e}
.msg-bubble code:not(pre code){background:var(--bg3);padding:2px 5px;border-radius:4px;font-size:13px;font-family:monospace}
.msg-bubble pre code{background:transparent;padding:0;font-family:'Fira Code','Cascadia Code',monospace}
.msg-image{max-width:200px;border-radius:var(--radius-sm);margin-bottom:8px}

/* image preview in input */
.img-preview{display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--bg2);border-top:1px solid var(--border);font-size:12px;color:var(--text2)}
.img-preview img{height:48px;border-radius:4px}
.img-preview-remove{background:none;border:none;color:var(--text3);cursor:pointer;font-size:16px;padding:0 4px}
.img-preview-remove:hover{color:var(--text)}

/* ── INPUT AREA ── */
.input-wrap{padding:12px 20px 20px;background:var(--bg)}
.input-container{max-width:720px;margin:0 auto}
.input-box{background:var(--input-bg);border:1px solid var(--input-border);border-radius:var(--radius);overflow:hidden;transition:border-color 0.15s}
.input-box:focus-within{border-color:var(--border2)}
.input-row{display:flex;align-items:flex-end;gap:8px;padding:10px 12px}
#chat-input{flex:1;background:transparent;border:none;color:var(--text);font-size:14.5px;font-family:inherit;resize:none;outline:none;min-height:24px;max-height:200px;line-height:1.5;overflow-y:auto}
#chat-input::placeholder{color:var(--text3)}
#chat-input::-webkit-scrollbar{width:4px}
#chat-input::-webkit-scrollbar-thumb{background:var(--bg4)}
.input-actions{display:flex;align-items:center;gap:6px;padding-bottom:2px}
.input-btn{width:34px;height:34px;border:1px solid var(--border);background:transparent;color:var(--text2);border-radius:var(--radius-xs);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all 0.15s}
.input-btn:hover{background:var(--bg3);color:var(--text)}
.input-btn.active{background:var(--accent);border-color:var(--accent);color:#fff}
#send-btn{background:var(--accent);border-color:var(--accent);color:#fff}
#send-btn:hover{opacity:0.85}
#send-btn:disabled{opacity:0.35;cursor:not-allowed}
#stop-btn{display:none;background:var(--bg3);border-color:var(--border2);color:var(--text)}
#stop-btn:hover{background:var(--error);border-color:var(--error);color:#fff}
.mic-listening{background:var(--error)!important;border-color:var(--error)!important;color:#fff!important;animation:micPulse 1s ease infinite}
@keyframes micPulse{0%,100%{opacity:1}50%{opacity:0.6}}
.input-footer{display:flex;justify-content:space-between;align-items:center;padding:0 4px;margin-top:6px;font-size:11px;color:var(--text3)}

/* ── STATUS BAR ── */
.status-bar{display:flex;align-items:center;gap:8px;padding:6px 16px;border-top:1px solid var(--border);background:var(--bg2);font-size:11px;color:var(--text3)}
.status-dot{width:6px;height:6px;border-radius:50%;background:var(--text3)}
.status-dot.green{background:var(--success)}
.status-dot.red{background:var(--error)}
.status-dot.yellow{background:var(--warn)}
.status-sep{color:var(--border2);margin:0 2px}

/* ── TOAST ── */
.toast{position:fixed;bottom:60px;left:50%;transform:translateX(-50%);background:var(--bg3);border:1px solid var(--border2);color:var(--text);padding:10px 18px;border-radius:var(--radius);font-size:13px;z-index:200;box-shadow:0 4px 16px rgba(0,0,0,0.4);opacity:0;transition:opacity 0.2s;pointer-events:none}
.toast.show{opacity:1}

/* ── MODE BUTTON ── */
#mode-btn{background:var(--bg3);border:1px solid var(--border2);color:var(--text2);border-radius:var(--radius-xs);padding:0 10px;height:32px;font-size:15px;cursor:pointer;flex-shrink:0}
#mode-btn:hover{border-color:var(--accent);color:var(--accent)}

/* ── SETTINGS MODAL ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);z-index:100;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:28px;width:100%;max-width:480px;max-height:90vh;overflow-y:auto}
.modal h2{font-size:18px;font-weight:600;margin-bottom:20px}
.modal-section{margin-bottom:20px}
.modal-section h3{font-size:12px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px}
.form-row{margin-bottom:10px}
.form-label{display:block;font-size:12px;color:var(--text2);margin-bottom:4px}
.form-input{width:100%;padding:8px 10px;background:var(--bg);border:1px solid var(--border);color:var(--text);border-radius:var(--radius-xs);font-size:13px;font-family:monospace}
.form-input:focus{outline:none;border-color:var(--accent)}
.form-input.textarea{font-family:inherit;font-size:13px;resize:vertical;min-height:80px}
.modal-actions{display:flex;gap:8px;margin-top:20px}
.btn-primary{flex:1;padding:10px;background:var(--accent);color:#fff;border:none;border-radius:var(--radius-xs);font-size:14px;font-weight:500;cursor:pointer;font-family:inherit}
.btn-primary:hover{opacity:0.9}
.btn-secondary{padding:10px 16px;background:transparent;border:1px solid var(--border);color:var(--text2);border-radius:var(--radius-xs);font-size:14px;cursor:pointer;font-family:inherit}
.btn-secondary:hover{background:var(--bg3)}
.key-row{display:flex;gap:6px}
.key-row .form-input{flex:1}
.verify-btn{padding:8px 12px;background:transparent;border:1px solid var(--border);color:var(--text2);border-radius:var(--radius-xs);font-size:12px;cursor:pointer;font-family:inherit;white-space:nowrap}
.verify-btn:hover{background:var(--bg3)}
.verify-status{font-size:11px;margin-top:4px;min-height:16px}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px}

/* ── RESPONSIVE ── */
/* ── TABLET (portrait + landscape) ── */
@media(max-width:900px){
  .sidebar{width:220px;min-width:220px}
  .messages-wrap{max-width:100%}
}

/* ── MOBILE PORTRAIT ── */
@media(max-width:700px){
  .sidebar{display:none}
  .sidebar.mobile-open{display:flex;position:fixed;inset:0;z-index:50;width:80vw;max-width:300px}
  .sidebar-open-btn{display:flex}
  .messages-wrap{padding:0 10px;max-width:100%}
  .suggestion-grid{grid-template-columns:1fr}
  .header{padding:8px 10px;gap:6px}
  .model-select{font-size:12px;min-width:120px;max-width:160px}
  .toggles{gap:4px}
  .toggle-btn{font-size:11px;padding:4px 7px}
  .theme-dots{gap:4px}
  .theme-dot{width:16px;height:16px}
  .input-wrap{padding:8px 10px 14px}
  .input-row{padding:8px 10px}
  #chat-input{font-size:16px}
  .input-btn{width:36px;height:36px;font-size:18px}
  .msg-avatar{width:26px;height:26px;min-width:26px;font-size:12px}
  .msg-bubble{font-size:14px;padding:10px 12px}
  .msg.ai .msg-bubble{padding-left:0}
  .empty-state h1{font-size:20px}
  .empty-state p{font-size:13px}
  .chat-area{padding:16px 0}
  .status-bar{font-size:10px;padding:4px 10px}
}

/* ── MOBILE LANDSCAPE ── */
@media(max-width:900px) and (orientation:landscape) and (max-height:500px){
  .sidebar{display:none}
  .sidebar-open-btn{display:flex}
  .header{padding:6px 10px}
  .chat-area{padding:8px 0}
  .input-wrap{padding:6px 10px 8px}
  .empty-state{padding:16px}
  .empty-state h1{font-size:18px}
  .suggestion-grid{grid-template-columns:1fr 1fr}
  .status-bar{display:none}
}

/* ── LARGE TABLET / IPAD PRO ── */
@media(min-width:701px) and (max-width:1024px){
  .messages-wrap{max-width:90%}
  .sidebar{width:220px;min-width:220px}
  .toggle-btn{font-size:12px}
}

/* touch: always show code copy btn */
@media(hover:none){
  .code-copy{opacity:1}
  .msg-actions{opacity:1}
}

/* ── PHONE MODE ── */
body.phone-mode .sidebar{display:none!important}
body.phone-mode .sidebar-open-btn{display:flex!important}
body.phone-mode .messages-wrap{max-width:100%;padding:0 8px}
body.phone-mode .input-container{max-width:100%}
body.phone-mode .header{flex-wrap:wrap;gap:6px;padding:8px 10px}
body.phone-mode .model-select{font-size:12px;min-width:110px}
body.phone-mode .toggle-btn{font-size:11px;padding:4px 8px}
body.phone-mode #chat-input{font-size:16px}
body.phone-mode .input-btn{width:40px;height:40px;font-size:20px}
body.phone-mode .theme-dots{display:none}

/* ── NO-MOUSE / KEYBOARD MODE ── */
body.no-mouse *:focus{outline:2px solid var(--accent)!important;outline-offset:2px}
body.no-mouse .msg-actions{opacity:1!important}
body.no-mouse .code-copy{opacity:1!important}
body.no-mouse .session-item{border:1px solid transparent}
body.no-mouse .session-item:focus{background:var(--bg3);color:var(--text);border-color:var(--accent);outline:none}
#kb-hint-bar{display:none;position:fixed;bottom:0;left:0;right:0;padding:5px 16px;background:var(--bg2);border-top:1px solid var(--border);font-size:11px;color:var(--text3);z-index:200;gap:10px;flex-wrap:wrap;align-items:center}
body.no-mouse #kb-hint-bar{display:flex}
.kb-hint-key{background:var(--bg3);border:1px solid var(--border2);border-radius:3px;padding:1px 6px;font-size:10px;color:var(--text);margin-right:3px;font-family:monospace}

/* ── FOCUS RINGS ── */
button:focus-visible,select:focus-visible,textarea:focus-visible{outline:2px solid var(--accent);outline-offset:2px}

/* ── AI MODE BUTTON ── */
#ai-mode-btn{padding:0 12px;height:32px;border:1px solid var(--border2);background:var(--bg3);color:var(--accent);border-radius:var(--radius-xs);font-size:12px;font-weight:600;cursor:pointer;letter-spacing:0.05em;flex-shrink:0}
#ai-mode-btn:hover{border-color:var(--accent)}
#ai-mode-btn.mode-plan{color:#fa0;border-color:#fa0}
#ai-mode-btn.mode-auto{color:#e55;border-color:#e55}

/* ── KEYBOARD HELP ── */
#kb-help{display:none;position:fixed;inset:0;z-index:300;background:rgba(0,0,0,0.7);align-items:center;justify-content:center}
#kb-help.open{display:flex}
#kb-help-box{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--radius);padding:24px 28px;min-width:320px;max-width:420px}
#kb-help-box h3{margin:0 0 16px;font-size:15px;color:var(--text)}
.kb-row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--border);font-size:13px}
.kb-row:last-child{border:none}
.kb-key{color:var(--accent);font-family:monospace;font-weight:600}
.kb-desc{color:var(--text2)}
</style>
</head>
<body>

<!-- WELCOME OVERLAY -->
<div id="welcome-overlay" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.85);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;">
  <div style="background:#1a1a2e;border:1px solid #0e9aa7;border-radius:16px;padding:40px;max-width:480px;width:90%;text-align:center;box-shadow:0 0 60px rgba(14,154,167,0.3);">
    <div style="font-size:48px;margin-bottom:8px;">🥷</div>
    <h1 style="color:#0e9aa7;font-size:28px;font-weight:700;margin:0 0 4px;">Master AI</h1>
    <p style="color:#888;font-size:13px;margin:0 0 24px;letter-spacing:2px;text-transform:uppercase;">Your Personal AI — Runs Locally</p>
    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:28px;text-align:left;">
      <div style="background:#0e1628;border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:12px;">
        <span style="font-size:20px;">🖥️</span>
        <div><div style="color:#fff;font-size:14px;font-weight:600;">Runs on your computer</div><div style="color:#888;font-size:12px;">No cloud. Your data never leaves.</div></div>
      </div>
      <div style="background:#0e1628;border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:12px;">
        <span style="font-size:20px;">💳</span>
        <div><div style="color:#fff;font-size:14px;font-weight:600;">No subscriptions. Ever.</div><div style="color:#888;font-size:12px;">One purchase. Yours for life.</div></div>
      </div>
      <div style="background:#0e1628;border-radius:8px;padding:12px 16px;display:flex;align-items:center;gap:12px;">
        <span style="font-size:20px;">🎙️</span>
        <div><div style="color:#fff;font-size:14px;font-weight:600;">Voice, vision, web search</div><div style="color:#888;font-size:12px;">Talk to it. Show it images. Ask anything.</div></div>
      </div>
    </div>
    <p style="color:#aaa;font-size:13px;margin-bottom:20px;">Start by typing or speaking — ask it anything, or say <em style="color:#0e9aa7;">"help me get started"</em></p>
    <button onclick="dismissWelcome()" style="background:#0e9aa7;color:#fff;border:none;border-radius:8px;padding:12px 36px;font-size:15px;font-weight:600;cursor:pointer;width:100%;">Get Started →</button>
    <div style="margin-top:14px;">
      <label style="color:#666;font-size:12px;cursor:pointer;">
        <input type="checkbox" id="no-show-again" style="margin-right:6px;">Don't show this again
      </label>
    </div>
  </div>
</div>
<script>
(function(){
  if(!localStorage.getItem('mai_welcomed')){
    document.getElementById('welcome-overlay').style.display='flex';
  }
})();
function dismissWelcome(){
  if(document.getElementById('no-show-again').checked){
    localStorage.setItem('mai_welcomed','1');
  }
  document.getElementById('welcome-overlay').style.display='none';
}
</script>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <button class="new-chat-btn" onclick="newChat()">+ New chat</button>
    <button onclick="clearAllSessions()" title="Delete all saved chats"
      style="font-size:11px;opacity:0.7;background:none;border:1px solid var(--border);
             border-radius:4px;padding:2px 8px;cursor:pointer;color:var(--text2)">
      Clear All
    </button>
    <button class="sidebar-toggle" onclick="toggleSidebar()" title="Close">✕</button>
  </div>
  <div class="sessions-list" id="sessions-list"></div>
  <div class="sidebar-footer">
    <button class="settings-btn" onclick="openSettings()">⚙ Settings &amp; API Keys</button>
  </div>
</aside>

<!-- MAIN -->
<div class="main">

  <!-- HEADER -->
  <div class="header">
    <button class="sidebar-open-btn" id="sidebar-open-btn" onclick="toggleSidebar()">☰</button>
    <button id="ai-mode-btn" onclick="cycleAiMode()" title="Cycle AI mode (Ctrl+K)">SAFE</button>
    <select class="model-select" id="provider-sel" onchange="setProvider(this.value)" title="Provider">
      <option value="master-ai">master-ai (local)</option>
      <option value="qwen2.5-coder">qwen2.5-coder (local)</option>
      <option value="groq">Groq · llama-3.3-70b</option>
      <option value="openai">OpenAI · gpt-4o</option>
      <option value="openrouter">OpenRouter · free</option>
      <option value="auto">⚡ Auto-Route</option>
    </select>
    <div class="header-spacer"></div>
    <div class="toggles">
      <button class="toggle-btn" id="tts-toggle" onclick="toggle('tts')" title="Auto-speak responses">
        <span class="toggle-dot"></span> Voice Out
      </button>
      <button class="toggle-btn" id="stt-toggle" onclick="toggle('stt')" title="Continuous voice input">
        <span class="toggle-dot"></span> Voice In
      </button>
      <button class="toggle-btn" id="search-toggle" onclick="toggle('search')" title="Include web search results">
        <span class="toggle-dot"></span> Web Search
      </button>
      <button class="toggle-btn" id="phone-btn" onclick="togglePhoneMode()" title="Phone mode (Shift+Tab)">
        <span class="toggle-dot"></span> 📱
      </button>
      <button class="toggle-btn" id="nomouse-btn" onclick="toggleNoMouse()" title="Keyboard mode (Ctrl+Shift+K)">
        <span class="toggle-dot"></span> ⌨️
      </button>
    </div>
    <div class="theme-dots">
      <button class="theme-dot" data-theme="dark"    title="Dark"      style="background:#212121" onclick="setTheme('dark')"></button>
      <button class="theme-dot" data-theme="light"   title="Light"     style="background:#f0eeeb;border-color:#ccc" onclick="setTheme('light')"></button>
      <button class="theme-dot" data-theme="ocean"   title="Ocean"     style="background:#00b4d8" onclick="setTheme('ocean')"></button>
      <button class="theme-dot" data-theme="midnight" title="Midnight" style="background:#7c6fcd" onclick="setTheme('midnight')"></button>
      <button class="theme-dot" data-theme="sunkissed" title="Sunkissed" style="background:#f5a623" onclick="setTheme('sunkissed')"></button>
    </div>
  </div>

  <!-- CHAT AREA -->
  <div class="chat-area" id="chat-area">
    <div class="messages-wrap" id="messages">
      <div class="empty-state" id="empty-state">
        <h1>🥷 Master AI</h1>
        <p>Vision · Voice · Web Search · Cloud Routing · Code<br/>All your AI tools in one place.</p>
        <div class="suggestion-grid">
          <button class="suggestion" onclick="quickSend('Search latest AI news today')">🌐 Latest AI news</button>
          <button class="suggestion" onclick="quickSend('Write a Python script to rename all files in a folder')">💻 Python file rename script</button>
          <button class="suggestion" onclick="quickSend('Explain how Tailscale VPN works')">🔐 How Tailscale works</button>
          <button class="suggestion" onclick="quickSend('What can you do?')">✨ What can you do?</button>
        </div>
      </div>
    </div>
  </div>

  <!-- IMAGE PREVIEW (shown when image attached) -->
  <div class="img-preview" id="img-preview" style="display:none">
    <img id="img-preview-thumb" src="" alt=""/>
    <span id="img-preview-name"></span>
    <button class="img-preview-remove" onclick="removeImage()" title="Remove">✕</button>
  </div>

  <!-- INPUT -->
  <div class="input-wrap">
    <div class="input-container">
      <div class="input-box">
        <div class="input-row">
          <button id="mode-btn" onclick="toggleInputMode()" title="Switch text/voice">⌨️</button>
          <textarea id="chat-input" placeholder="Message Master AI…" rows="1"
            onkeydown="inputKeydown(event)" oninput="autoResize(this)"></textarea>
          <div class="input-actions">
            <button class="input-btn" id="attach-btn" onclick="attachImage()" title="Attach image">📎</button>
            <input type="file" id="file-input" accept="image/*" style="display:none" onchange="handleImage(event)"/>
            <button class="input-btn" id="mic-btn" onclick="micClick()" title="Voice input">🎤</button>
            <button class="input-btn" id="stop-btn" onclick="stopStream()" title="Stop">⏹</button>
            <button class="input-btn" id="send-btn" onclick="sendMsg()" title="Send (Enter)">↑</button>
          </div>
        </div>
      </div>
      <div class="input-footer">
        <span id="route-info"></span>
        <span>Shift+Enter newline · <b>?</b> shortcuts · Shift+Tab 📱 · Ctrl+Shift+K ⌨️ · Ctrl+K mode</span>
      </div>
    </div>
  </div>

  <!-- STATUS BAR -->
  <div class="status-bar">
    <span class="status-dot green" id="pc-dot"></span>
    <span id="pc-status">Madam-Mary</span>
    <span class="status-sep">│</span>
    <span class="status-dot" id="ollama-dot"></span>
    <span id="ollama-status">Checking...</span>
    <span class="status-sep">│</span>
    <span class="status-dot" id="tts-dot"></span>
    <span id="tts-status">TTS</span>
    <span style="margin-left:auto" id="token-count"></span>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- SETTINGS MODAL -->
<div class="modal-overlay" id="settings-modal">
  <div class="modal">
    <h2>⚙ Settings</h2>

    <div class="modal-section">
      <h3>API Keys</h3>
      <div class="form-row">
        <label class="form-label">Groq API Key</label>
        <div class="key-row">
          <input type="password" class="form-input" id="groq-key-input" placeholder="gsk_..."/>
          <button class="verify-btn" onclick="verifyKey('groq')">Verify</button>
        </div>
        <div class="verify-status" id="groq-status"></div>
      </div>
      <div class="form-row">
        <label class="form-label">OpenAI API Key</label>
        <div class="key-row">
          <input type="password" class="form-input" id="openai-key-input" placeholder="sk-proj-..."/>
          <button class="verify-btn" onclick="verifyKey('openai')">Verify</button>
        </div>
        <div class="verify-status" id="openai-status"></div>
      </div>
      <div class="form-row">
        <label class="form-label">OpenRouter API Key</label>
        <div class="key-row">
          <input type="password" class="form-input" id="openrouter-key-input" placeholder="sk-or-v1-..."/>
          <button class="verify-btn" onclick="verifyKey('openrouter')">Verify</button>
        </div>
        <div class="verify-status" id="openrouter-status"></div>
      </div>
    </div>

    <div class="modal-section">
      <h3>Ollama</h3>
      <div class="form-row">
        <label class="form-label">Host</label>
        <input type="text" class="form-input" id="ollama-host-input" value="http://localhost:11434"/>
      </div>
    </div>

    <div class="modal-section">
      <h3>TTS Server</h3>
      <div class="form-row">
        <label class="form-label">Host (Piper TTS)</label>
        <input type="text" class="form-input" id="tts-host-input" value="http://localhost:5050"/>
      </div>
    </div>

    <div class="modal-section">
      <h3>System Prompt</h3>
      <div class="form-row">
        <textarea class="form-input textarea" id="sys-prompt-input" rows="4">You are Master AI — a highly capable, honest, and helpful AI assistant running on Elijah's Linux machine (Madam-Mary). You are direct, concise, and deliver complete working solutions. Never say you can't when a workaround exists.</textarea>
      </div>
    </div>

    <div class="modal-actions">
      <button class="btn-secondary" onclick="closeSettings()">Cancel</button>
      <button class="btn-primary" onclick="saveSettings()">Save Settings</button>
    </div>
  </div>
</div>

<script>
// ── STATE ────────────────────────────────────────────────────
const S = {
  provider: 'master-ai',
  toggles: { tts: false, stt: false, search: false },
  history: [],
  sessions: [],
  keys: {},
  ollama: 'http://localhost:11434',
  tts: 'http://localhost:5050',
  sysPrompt: 'You are Master AI — a task-executing AI service agent built by Elijah, running on Madam-Mary (Ubuntu Linux). You are a service tool, not a conversational assistant. When given a task, do it — write full working code, complete files, direct answers. Never say you cannot when a workaround exists. Shell environment: bash on Ubuntu. Use standard bash, sudo for elevated permissions, apt for installs.',
  streaming: false,
  abort: null,
  msgQueue: [],
  noMouse: false,
  kbZone: 'input',
  attachedImage: null, // { dataUrl, name }
  mediaRecorder: null,
  audioChunks: [],
  micStream: null,
  micActive: false,
  phoneMode: false,
  aiMode: 'SAFE',
  inputMode: 'text',
};

// ── INIT ─────────────────────────────────────────────────────
function init() {
  loadSettings();
  renderSessions();
  checkOllama();
  checkTTS();
  updateToggles();
  applyInputMode();
  setInterval(() => { checkOllama(); checkTTS(); }, 30000);
  if (S.inputMode === 'text') document.getElementById('chat-input').focus();
  loadDiskSessions();
  S.phoneMode = localStorage.getItem('mai_phone_mode') === 'true';
  document.body.classList.toggle('phone-mode', S.phoneMode);
  const pb = document.getElementById('phone-btn');
  if (pb) pb.classList.toggle('on', S.phoneMode);
  S.noMouse = localStorage.getItem('mai_no_mouse') === 'true';
  document.body.classList.toggle('no-mouse', S.noMouse);
  const nb = document.getElementById('nomouse-btn');
  if (nb) nb.classList.toggle('on', S.noMouse);
  S.aiMode = localStorage.getItem('mai_ai_mode') || 'SAFE';
  updateAiModeBtn();
  updateTokenCount();
  if (!S.keys.groq && !S.keys.openai && !S.keys.openrouter) {
    setTimeout(() => openSettings(), 800);
  }
}

// ── SETTINGS ─────────────────────────────────────────────────
function loadSettings() {
  S.keys.groq       = localStorage.getItem('mai_groq') || '';
  S.keys.openai     = localStorage.getItem('mai_openai') || '';
  S.keys.openrouter = localStorage.getItem('mai_openrouter') || '';
  S.ollama          = localStorage.getItem('mai_ollama') || 'http://localhost:11434';
  S.tts             = localStorage.getItem('mai_tts') || 'http://localhost:5050';
  S.sysPrompt       = localStorage.getItem('mai_sysprompt') || S.sysPrompt;
  S.provider        = localStorage.getItem('mai_provider') || 'master-ai';
  S.toggles.tts     = localStorage.getItem('mai_tts_on') === 'true';
  S.toggles.search  = localStorage.getItem('mai_search_on') === 'true';
  S.sessions        = JSON.parse(localStorage.getItem('mai_sessions') || '[]');
  S.inputMode       = localStorage.getItem('mai_input_mode') || 'text';
  document.getElementById('provider-sel').value = S.provider;
}

function openSettings() {
  document.getElementById('groq-key-input').value = S.keys.groq;
  document.getElementById('openai-key-input').value = S.keys.openai;
  document.getElementById('openrouter-key-input').value = S.keys.openrouter;
  document.getElementById('ollama-host-input').value = S.ollama;
  document.getElementById('tts-host-input').value = S.tts;
  document.getElementById('sys-prompt-input').value = S.sysPrompt;
  document.getElementById('settings-modal').classList.add('open');
}

function closeSettings() {
  document.getElementById('settings-modal').classList.remove('open');
}

function saveSettings() {
  S.keys.groq       = document.getElementById('groq-key-input').value.trim();
  S.keys.openai     = document.getElementById('openai-key-input').value.trim();
  S.keys.openrouter = document.getElementById('openrouter-key-input').value.trim();
  S.ollama          = document.getElementById('ollama-host-input').value.trim();
  S.tts             = document.getElementById('tts-host-input').value.trim();
  S.sysPrompt       = document.getElementById('sys-prompt-input').value.trim();
  localStorage.setItem('mai_groq', S.keys.groq);
  localStorage.setItem('mai_openai', S.keys.openai);
  localStorage.setItem('mai_openrouter', S.keys.openrouter);
  localStorage.setItem('mai_ollama', S.ollama);
  localStorage.setItem('mai_tts', S.tts);
  localStorage.setItem('mai_sysprompt', S.sysPrompt);
  closeSettings();
  checkOllama();
}

async function verifyKey(provider) {
  const statusEl = document.getElementById(provider + '-status');
  statusEl.style.color = 'var(--warn)';
  statusEl.textContent = 'Verifying...';
  const key = document.getElementById(provider + '-key-input').value.trim();
  if (!key) { statusEl.style.color = 'var(--error)'; statusEl.textContent = 'Enter a key first'; return; }
  try {
    let url, headers;
    if (provider === 'groq') {
      url = 'https://api.groq.com/openai/v1/models';
      headers = { 'Authorization': 'Bearer ' + key };
    } else if (provider === 'openai') {
      url = 'https://api.openai.com/v1/models';
      headers = { 'Authorization': 'Bearer ' + key };
    } else {
      url = 'https://openrouter.ai/api/v1/auth/key';
      headers = { 'Authorization': 'Bearer ' + key };
    }
    const res = await fetch(url, { headers });
    if (res.ok) {
      statusEl.style.color = 'var(--success)';
      statusEl.textContent = '✅ Valid';
    } else {
      throw new Error('HTTP ' + res.status);
    }
  } catch(e) {
    statusEl.style.color = 'var(--error)';
    statusEl.textContent = '❌ ' + e.message;
  }
}

// ── TOGGLES ──────────────────────────────────────────────────
function toggle(name) {
  S.toggles[name] = !S.toggles[name];
  localStorage.setItem('mai_' + name + '_on', S.toggles[name]);
  updateToggles();
  if (name === 'stt') {
    // Phone mode: don't auto-grab mic — phone keyboard handles voice natively
    if (S.toggles.stt && !S.phoneMode) startContinuousSTT(); else stopContinuousSTT();
  }
}

function updateToggles() {
  ['tts','stt','search'].forEach(n => {
    const btn = document.getElementById(n + '-toggle');
    if (btn) btn.classList.toggle('on', !!S.toggles[n]);
  });
}

// ── PROVIDER ─────────────────────────────────────────────────
function setProvider(v) {
  S.provider = v;
  localStorage.setItem('mai_provider', v);
  updateTokenCount();
}

function autoRoute(text) {
  const t = text.toLowerCase();
  const code = /\b(code|python|bash|javascript|script|debug|function|class|error|fix|bug|html|css)\b/;
  const web  = /\b(latest|today|current|news|search|price|weather|who is|recently|2025|2026)\b/;
  const deep = /\b(explain|analyze|compare|difference|pros|cons|strategy|why|how does|in depth)\b/;
  const vis  = /\b(image|photo|picture|see|show|look|describe|read this)\b/;
  const hasGroq = !!(S.keys && S.keys.groq);
  const hasOpenAI = !!(S.keys && S.keys.openai);
  if (vis.test(t) && S.attachedImage) return 'master-ai';
  if (code.test(t)) return 'qwen2.5-coder';
  if (web.test(t) || S.toggles.search) return hasGroq ? 'groq' : 'master-ai';
  if (deep.test(t)) return hasOpenAI ? 'openai' : (hasGroq ? 'groq' : 'master-ai');
  return 'master-ai';
}

// ── OLLAMA STATUS ─────────────────────────────────────────────
async function checkOllama() {
  try {
    const res = await fetch(S.ollama + '/api/tags', { signal: AbortSignal.timeout(3000) });
    if (res.ok) {
      document.getElementById('ollama-dot').className = 'status-dot green';
      document.getElementById('ollama-status').textContent = 'Ollama connected';
      const data = await res.json();
      updateModelOptions(data.models || []);
      return;
    }
  } catch {}
  document.getElementById('ollama-dot').className = 'status-dot red';
  document.getElementById('ollama-status').textContent = 'Ollama offline';
}

async function checkTTS() {
  try {
    await fetch(S.tts + '/health', { signal: AbortSignal.timeout(2000) });
    document.getElementById('tts-dot').className = 'status-dot green';
    document.getElementById('tts-status').textContent = 'TTS ready';
  } catch {
    document.getElementById('tts-dot').className = 'status-dot yellow';
    document.getElementById('tts-status').textContent = 'TTS offline';
  }
}

// ── TOAST ────────────────────────────────────────────────────
let toastTimer = null;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 4000);
}

// ── INPUT MODE ───────────────────────────────────────────────
function toggleInputMode() {
  S.inputMode = S.inputMode === 'text' ? 'voice' : 'text';
  localStorage.setItem('mai_input_mode', S.inputMode);
  applyInputMode();
}

function applyInputMode() {
  const isVoice = S.inputMode === 'voice';
  document.getElementById('mode-btn').textContent = isVoice ? '🎤' : '⌨️';
  document.getElementById('mode-btn').title = isVoice ? 'Switch to text' : 'Switch to voice';
  document.getElementById('chat-input').style.display = isVoice ? 'none' : '';
  // Phone mode: never auto-grab mic — let phone keyboard voice input work natively
  if (S.phoneMode) {
    stopMic();
    document.getElementById('chat-input').focus();
    return;
  }
  if (isVoice) {
    if (!S.micActive) startMic(false);
  } else {
    stopMic();
    document.getElementById('chat-input').focus();
  }
}

function updateModelOptions(models) {
  const sel = document.getElementById('provider-sel');
  const localGroup = [...sel.options].slice(0, 2);
  // keep existing options, don't rebuild (avoids losing selection)
}

// ── WEB SEARCH ───────────────────────────────────────────────
async function webSearch(query) {
  try {
    const url = `https://api.duckduckgo.com/?q=${encodeURIComponent(query)}&format=json&no_html=1&skip_disambig=1`;
    const res = await fetch('https://api.allorigins.win/raw?url=' + encodeURIComponent(url));
    const data = await res.json();
    let results = '';
    if (data.AbstractText) results += data.AbstractText + '\n\n';
    if (data.RelatedTopics) {
      data.RelatedTopics.slice(0,4).forEach(t => {
        if (t.Text) results += '• ' + t.Text + '\n';
      });
    }
    return results || null;
  } catch { return null; }
}

// ── SEND ─────────────────────────────────────────────────────
function updateQueueBadge() {
  const btn = document.getElementById('send-btn');
  let badge = btn.querySelector('.queue-badge');
  if (!S.msgQueue || !S.msgQueue.length) {
    if (badge) badge.remove();
    return;
  }
  if (!badge) { badge = document.createElement('span'); badge.className = 'queue-badge'; btn.appendChild(badge); }
  badge.textContent = '⏳' + S.msgQueue.length;
}

async function sendMsg(queuedText, queuedImage) {
  const input = document.getElementById('chat-input');
  const text = queuedText !== undefined ? queuedText : input.value.trim();
  const imageData = queuedImage !== undefined ? queuedImage : S.attachedImage;

  if (!text && !imageData) return;

  if (S.streaming && queuedText === undefined) {
    if (!S.msgQueue) S.msgQueue = [];
    S.msgQueue.push({ text, imageData: S.attachedImage });
    updateQueueBadge();
    input.value = '';
    autoResize(input);
    return;
  }

  if (queuedText === undefined) {
    input.value = '';
    autoResize(input);
  }
  hideEmpty();

  let provider = S.provider === 'auto' ? autoRoute(text) : S.provider;

  // show route info
  const routeMap = {
    'master-ai':'local · master-ai','qwen2.5-coder':'local · coder',
    'groq':'cloud · Groq','openai':'cloud · GPT-4o','openrouter':'cloud · OpenRouter'
  };
  document.getElementById('route-info').textContent = '⚡ ' + (routeMap[provider] || provider);

  // add user message
  const imgDataUrl = imageData?.dataUrl || (typeof imageData === 'string' ? imageData : null);
  addMsg('user', text, imgDataUrl);

  S.history.push({ role: 'user', content: text });

  if (queuedText === undefined) removeImage();

  // web search augmentation
  let augmentedText = text;
  if (S.toggles.search || (S.provider === 'auto' && /latest|today|news|current|price|weather/.test(text.toLowerCase()))) {
    const results = await webSearch(text);
    if (results) augmentedText = text + '\n\n[Web search context]\n' + results;
  }

  await streamResponse(augmentedText, provider, imgDataUrl);
}

function quickSend(text) {
  document.getElementById('chat-input').value = text;
  sendMsg();
}

function inputKeydown(e) {
  const input = document.getElementById('chat-input');
  if (e.key === 'Tab' && e.shiftKey) { e.preventDefault(); if (S.noMouse) cycleZone(); else togglePhoneMode(); return; }
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    if (input.value.trim() === 'x') { input.value = ''; if (S.streaming) stopStream(); return; }
    sendMsg();
    return;
  }
  if (e.key === 'ArrowUp' && input.value === '') {
    e.preventDefault();
    const last = [...S.history].reverse().find(m => m.role === 'user');
    if (last) { input.value = last.content; autoResize(input); }
    return;
  }
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 200) + 'px';
}

// ── STREAM RESPONSE ───────────────────────────────────────────
async function streamResponse(userText, provider, imageData) {
  S.streaming = true;
  S.abort = new AbortController();
  document.getElementById('stop-btn').style.display = 'flex';
  document.getElementById('send-btn').disabled = true;

  const thinking = addThinking(provider);
  let fullText = '';

  const sysMsg = { role: 'system', content: S.sysPrompt + (AI_MODE_PROMPTS[S.aiMode] || '') };
  const msgs = [sysMsg, ...S.history.slice(-20)];

  // inject image into last user message if present
  if (imageData && provider === 'master-ai') {
    const last = msgs[msgs.length - 1];
    last.images = [imageData.replace(/^data:[^;]+;base64,/, '')];
  }

  try {
    if (provider === 'openai') {
      fullText = await callOpenAI(msgs);
    } else if (provider === 'groq') {
      fullText = await callOpenAICompat('https://api.groq.com/openai/v1/chat/completions',
        S.keys.groq, 'llama-3.3-70b-versatile', msgs, thinking);
    } else if (provider === 'openrouter') {
      fullText = await callOpenAICompat('https://openrouter.ai/api/v1/chat/completions',
        S.keys.openrouter, 'meta-llama/llama-3.3-70b-instruct:free', msgs, thinking);
    } else {
      // Ollama (master-ai or qwen2.5-coder)
      const model = provider === 'qwen2.5-coder' ? 'qwen2.5-coder:7b' : 'master-ai';
      fullText = await callOllama(model, msgs, thinking, imageData);
    }
  } catch(e) {
    if (e.name !== 'AbortError') {
      fullText = 'Error: ' + e.message;
    }
  }

  if (!fullText) fullText = '[stopped]';

  thinking.classList.remove('thinking');
  renderFinal(thinking, fullText);
  S.history.push({ role: 'assistant', content: fullText });

  S.streaming = false;
  S.abort = null;
  document.getElementById('stop-btn').style.display = 'none';
  document.getElementById('send-btn').disabled = false;

  updateTokenCount(provider);

  if (S.toggles.tts && fullText && fullText !== '[stopped]') {
    speakText(fullText.slice(0, 500));
  }

  autosaveSession();

  // drain message queue
  if (S.msgQueue && S.msgQueue.length) {
    const next = S.msgQueue.shift();
    updateQueueBadge();
    setTimeout(() => sendMsg(next.text, next.imageData), 100);
  }
}

async function callOllama(model, msgs, thinking, imageData) {
  const body = { model, messages: msgs, stream: true };
  const res = await fetch(S.ollama + '/api/chat', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body), signal: S.abort.signal
  });
  const reader = res.body.getReader();
  const dec = new TextDecoder();
  let full = '';
  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    for (const line of dec.decode(value).split('\n')) {
      if (!line.trim()) continue;
      try {
        const d = JSON.parse(line);
        const t = d.message?.content || '';
        full += t;
        thinking.querySelector('.msg-text').innerHTML = renderMd(full) + '<span class="thinking-dot"></span>';
        scrollBottom();
      } catch {}
    }
  }
  return full;
}

async function callOpenAICompat(url, key, model, msgs, thinking) {
  if (!key) throw new Error('API key not set — open Settings');
  const res = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + key,
                'HTTP-Referer': 'http://localhost', 'X-Title': 'MasterAI' },
    body: JSON.stringify({ model, messages: msgs, stream: true }),
    signal: S.abort.signal
  });
  if (!res.ok) throw new Error(res.status === 400 ? 'API key rejected (400) — check Settings → Keys' : 'HTTP ' + res.status);
  const reader = res.body.getReader();
  const dec = new TextDecoder();
  let full = '';
  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    for (const line of dec.decode(value).split('\n')) {
      if (!line.startsWith('data:') || line.includes('[DONE]')) continue;
      try {
        const d = JSON.parse(line.replace(/^data: /, ''));
        const t = d.choices?.[0]?.delta?.content || '';
        full += t;
        thinking.querySelector('.msg-text').innerHTML = renderMd(full) + '<span class="thinking-dot"></span>';
        scrollBottom();
      } catch {}
    }
  }
  return full;
}

async function callOpenAI(msgs) {
  if (!S.keys.openai) throw new Error('OpenAI key not set — open Settings');
  const res = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + S.keys.openai },
    body: JSON.stringify({ model: 'gpt-4o', messages: msgs, max_tokens: 2048 }),
    signal: S.abort.signal
  });
  if (!res.ok) throw new Error('OpenAI HTTP ' + res.status);
  const data = await res.json();
  return data.choices?.[0]?.message?.content || '';
}

function stopStream() {
  if (S.abort) { S.abort.abort(); S.abort = null; }
  S.streaming = false;
  document.getElementById('stop-btn').style.display = 'none';
  document.getElementById('send-btn').disabled = false;
}

// ── TTS ───────────────────────────────────────────────────────
async function speakText(text) {
  try {
    await fetch(S.tts + '/speak', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text })
    });
  } catch {}
}

// ── STT (Whisper via local /stt endpoint) ────────────────────
function micClick() {
  if (S.micActive) { stopMic(); return; }
  startMic(false);
}

async function startMic(continuous) {
  let stream;
  try {
    stream = await navigator.mediaDevices.getUserMedia({ audio: true });
  } catch (err) {
    showToast('🎤 Mic permission denied — allow mic in browser settings.');
    return;
  }
  S.audioChunks = [];
  S.micStream = stream;
  S.mediaRecorder = new MediaRecorder(stream);
  S.mediaRecorder.ondataavailable = e => { if (e.data.size > 0) S.audioChunks.push(e.data); };
  S.mediaRecorder.onstop = async () => {
    stream.getTracks().forEach(t => t.stop());
    const blob = new Blob(S.audioChunks, { type: 'audio/webm' });
    showToast('📝 Transcribing…');
    try {
      const res = await fetch('/stt', { method: 'POST', body: blob,
        headers: { 'Content-Type': 'audio/webm' } });
      const data = await res.json();
      if (data.error) { showToast('🎤 STT error: ' + data.error); return; }
      if (data.text) {
        const input = document.getElementById('chat-input');
        input.value = data.text;
        autoResize(input);
        input.focus();
      } else {
        showToast('🎤 No speech detected. Try again.');
      }
    } catch (e) {
      showToast('🎤 STT failed — is the server running?');
    }
    if (continuous && S.toggles.stt) setTimeout(() => startMic(true), 300);
  };
  S.micActive = true;
  S.mediaRecorder.start();
  document.getElementById('mic-btn').classList.add('mic-listening');
}

function startContinuousSTT() { startMic(true); }
function stopContinuousSTT() { stopMic(); }

function stopMic() {
  S.micActive = false;
  document.getElementById('mic-btn').classList.remove('mic-listening');
  if (S.mediaRecorder && S.mediaRecorder.state !== 'inactive') S.mediaRecorder.stop();
  S.mediaRecorder = null;
}

// ── IMAGE ATTACH ──────────────────────────────────────────────
function attachImage() { document.getElementById('file-input').click(); }
function handleImage(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    S.attachedImage = { dataUrl: ev.target.result, name: file.name };
    document.getElementById('img-preview-thumb').src = ev.target.result;
    document.getElementById('img-preview-name').textContent = file.name;
    document.getElementById('img-preview').style.display = 'flex';
  };
  reader.readAsDataURL(file);
  e.target.value = '';
}
function removeImage() {
  S.attachedImage = null;
  document.getElementById('img-preview').style.display = 'none';
  document.getElementById('img-preview-thumb').src = '';
}

// ── MESSAGES ──────────────────────────────────────────────────
function addMsg(role, text, imgDataUrl) {
  const msgs = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'msg ' + role;
  const initials = role === 'ai' ? 'M' : 'E';
  let imgHtml = imgDataUrl ? `<img class="msg-image" src="${imgDataUrl}" alt="image"/>` : '';
  div.innerHTML = `
    <div class="msg-avatar">${initials}</div>
    <div class="msg-body">
      <div class="msg-bubble">${imgHtml}<div class="msg-text">${role === 'user' ? escHtml(text) : renderMd(text)}</div></div>
      ${role === 'ai' ? `<div class="msg-actions">
        <button class="msg-action-btn" onclick="copyMsg(this)">Copy</button>
        <button class="msg-action-btn" onclick="speakMsg(this)">Speak</button>
        <button class="msg-action-btn" onclick="regenMsg(this)">Retry</button>
      </div>` : ''}
    </div>`;
  msgs.appendChild(div);
  scrollBottom();
  return div;
}

function addThinking(provider) {
  const msgs = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'msg ai thinking';
  const label = provider.includes('groq') ? 'groq' : provider.includes('openai') ? 'gpt-4o' :
                 provider.includes('openrouter') ? 'openrouter' : provider;
  div.innerHTML = `
    <div class="msg-avatar">M</div>
    <div class="msg-body">
      <div class="route-tag">${label}</div>
      <div class="msg-bubble"><div class="msg-text">
        <span style="margin-right:5px;font-size:14px">🥷</span><span class="thinking-dot"></span><span class="thinking-dot"></span><span class="thinking-dot"></span>
      </div></div>
      <div class="msg-actions">
        <button class="msg-action-btn" onclick="copyMsg(this)">Copy</button>
        <button class="msg-action-btn" onclick="speakMsg(this)">Speak</button>
        <button class="msg-action-btn" onclick="regenMsg(this)">Retry</button>
      </div>
    </div>`;
  msgs.appendChild(div);
  scrollBottom();
  return div;
}

function renderFinal(el, text) {
  el.querySelector('.msg-text').innerHTML = renderMd(text);
  // highlight code
  el.querySelectorAll('pre code').forEach(block => {
    hljs.highlightElement(block);
    // wrap with copy button
    const pre = block.parentElement;
    if (!pre.parentElement.classList.contains('code-block')) {
      const lang = block.className.match(/language-(\w+)/)?.[1] || '';
      const wrap = document.createElement('div');
      wrap.className = 'code-block';
      pre.parentNode.insertBefore(wrap, pre);
      wrap.appendChild(pre);
      if (lang) wrap.insertAdjacentHTML('afterbegin', `<span class="code-lang">${lang}</span>`);
      wrap.insertAdjacentHTML('afterbegin', `<button class="code-copy" onclick="copyCode(this)">Copy</button>`);
    }
  });
  scrollBottom();
}

function copyMsg(btn) {
  const text = btn.closest('.msg').querySelector('.msg-text').textContent;
  navigator.clipboard.writeText(text).then(() => { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 1500); });
}

function speakMsg(btn) {
  const text = btn.closest('.msg').querySelector('.msg-text').textContent;
  speakText(text.slice(0, 600));
  btn.textContent = 'Speaking…';
  setTimeout(() => btn.textContent = 'Speak', 2500);
}

function regenMsg(btn) {
  const last = [...S.history].reverse().find(m => m.role === 'user');
  if (!last || S.streaming) return;
  S.history = S.history.filter(m => m !== last);
  btn.closest('.msg').remove();
  S.history.push({ role: 'user', content: last.content });
  streamResponse(last.content, S.provider === 'auto' ? autoRoute(last.content) : S.provider, null);
}

function copyCode(btn) {
  const code = btn.closest('.code-block').querySelector('code').textContent;
  navigator.clipboard.writeText(code).then(() => { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 1500); });
}

// ── SESSIONS ──────────────────────────────────────────────────
const PROVIDER_LIMITS = {
  'groq': 128000, 'openai': 128000, 'openrouter': 128000,
  'master-ai': null, 'qwen2.5-coder': null, 'auto': null
};

function updateTokenCount(routedProvider) {
  const allText = [S.sysPrompt, ...S.history.map(m => m.content)].join(' ');
  const estimated = Math.round(allText.length / 4);
  const p = routedProvider || S.provider;
  const limit = PROVIDER_LIMITS[p] ?? null;
  if (!limit) {
    document.getElementById('token-count').innerHTML =
      `<span style="color:#8b8;font-size:11px">~${estimated.toLocaleString()} tokens · unlimited</span>`;
    return;
  }
  const pct = Math.min(100, Math.round((estimated / limit) * 100));
  const remaining = Math.max(0, limit - estimated);
  const color = pct > 80 ? '#e55' : pct > 60 ? '#fa0' : '#8b8';
  document.getElementById('token-count').innerHTML =
    `<span style="color:${color};font-size:11px">~${estimated.toLocaleString()} / ${limit.toLocaleString()} tokens (${remaining.toLocaleString()} left)</span>`;
}

function autosaveSession() {
  if (!S.history.length) return;
  const first = S.history.find(m => m.role === 'user')?.content || 'Chat';
  const name = first.slice(0, 40) + (first.length > 40 ? '…' : '');
  const existing = S.sessions[0];
  const session = { name, date: new Date().toLocaleDateString(), messages: [...S.history], ts: Date.now(), source: 'Web UI' };
  if (existing && existing.ts && (Date.now() - existing.ts) < 3600000) {
    S.sessions[0] = session;
  } else {
    S.sessions.unshift(session);
    if (S.sessions.length > 40) S.sessions.pop();
  }
  localStorage.setItem('mai_sessions', JSON.stringify(S.sessions));
  renderSessions();
  fetch('/sessions', { method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(session) }).catch(() => {});
}

async function loadDiskSessions() {
  try {
    const res = await fetch('/sessions');
    if (!res.ok) return;
    const disk = await res.json();
    if (!disk.length) return;
    disk.forEach(ds => {
      if (!S.sessions.find(s => Math.abs(s.ts - ds.ts) < 1000)) {
        S.sessions.push(ds);
      }
    });
    if (S.sessions.length > 80) S.sessions.length = 80;
    localStorage.setItem('mai_sessions', JSON.stringify(S.sessions));
    renderSessions();
  } catch(e) {}
}

function renameSession(i, e) {
  e.stopPropagation();
  const item = e.target.closest('.session-item');
  const nameSpan = item.querySelector('.session-name');
  const current = S.sessions[i].name;
  const input = document.createElement('input');
  input.className = 'session-rename-input';
  input.value = current;
  nameSpan.replaceWith(input);
  input.focus();
  input.select();
  const finish = () => {
    const val = input.value.trim().slice(0, 60);
    if (val) S.sessions[i].name = val;
    localStorage.setItem('mai_sessions', JSON.stringify(S.sessions));
    renderSessions();
  };
  input.addEventListener('keydown', ev => {
    if (ev.key === 'Enter') { ev.preventDefault(); finish(); }
    if (ev.key === 'Escape') { renderSessions(); }
    ev.stopPropagation();
  });
  input.addEventListener('blur', finish);
}

function deleteSession(i, e) {
  e.stopPropagation();
  if (!confirm('Delete this chat?')) return;
  S.sessions.splice(i, 1);
  localStorage.setItem('mai_sessions', JSON.stringify(S.sessions));
  renderSessions();
}

function clearAllSessions() {
  if (!S.sessions.length) return;
  if (!confirm('Delete ALL saved chats? This cannot be undone.')) return;
  S.sessions = [];
  localStorage.setItem('mai_sessions', JSON.stringify(S.sessions));
  renderSessions();
}

function renderSessions() {
  const list = document.getElementById('sessions-list');
  if (!S.sessions.length) { list.innerHTML = '<div style="padding:10px;font-size:12px;color:var(--text3)">No saved chats</div>'; return; }
  list.innerHTML = S.sessions.map((s, i) => {
    const src = s.source || 'Web UI';
    const srcColor = src === 'Web UI' ? 'var(--accent)' : src === 'PC Control' ? '#f5a623' : 'var(--text3)';
    return `
    <div class="session-item" tabindex="0" data-idx="${i}"
      style="display:flex;align-items:center;gap:4px" title="${s.name}"
      onclick="loadSession(${i})"
      onkeydown="handleSessionKey(event,${i})">
      <div style="flex:1;overflow:hidden">
        <div style="display:flex;align-items:center;gap:4px">
          <span class="session-name" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1">${s.name}</span>
          <span style="flex-shrink:0;cursor:pointer;padding:0 4px;opacity:0.6;font-size:12px;touch-action:manipulation" onclick="renameSession(${i},event)" title="Rename">✏️</span>
          <span style="flex-shrink:0;cursor:pointer;padding:0 4px;opacity:0.6;font-size:12px;touch-action:manipulation" onclick="deleteSession(${i},event)" title="Delete">🗑️</span>
        </div>
        <span class="session-source" style="color:${srcColor}">${src} · ${s.date||''}</span>
      </div>
    </div>`;
  }).join('');
}

function handleSessionKey(e, i) {
  if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); loadSession(i); return; }
  if (e.key === 'ArrowDown') { e.preventDefault(); focusSession(i + 1); }
  if (e.key === 'ArrowUp')   { e.preventDefault(); focusSession(i - 1); }
  if (e.key === 'Escape')    { document.getElementById('chat-input').focus(); }
}

function focusSession(i) {
  const items = document.querySelectorAll('.session-item');
  const target = items[Math.max(0, Math.min(i, items.length - 1))];
  if (target) target.focus();
}

function loadSession(i) {
  const s = S.sessions[i];
  if (!s) return;
  newChat(false);
  S.history = [...s.messages];
  hideEmpty();
  s.messages.forEach(m => { if (m.role !== 'system') addMsg(m.role, m.content); });
}

function newChat(focus=true) {
  S.history = [];
  S.abort = null;
  document.getElementById('messages').innerHTML = `
    <div class="empty-state" id="empty-state">
      <h1>Master AI</h1>
      <p>Vision · Voice · Web Search · Cloud Routing · Code<br/>All your AI tools in one place.</p>
      <div class="suggestion-grid">
        <button class="suggestion" onclick="quickSend('Search latest AI news today')">🌐 Latest AI news</button>
        <button class="suggestion" onclick="quickSend('Write a Python script to rename all files in a folder')">💻 Python file rename script</button>
        <button class="suggestion" onclick="quickSend('Explain how Tailscale VPN works')">🔐 How Tailscale works</button>
        <button class="suggestion" onclick="quickSend('What can you do?')">✨ What can you do?</button>
      </div>
    </div>`;
  removeImage();
  document.getElementById('route-info').textContent = '';
  if (focus) document.getElementById('chat-input').focus();
}

function hideEmpty() {
  const es = document.getElementById('empty-state');
  if (es) es.remove();
}

// ── SIDEBAR ───────────────────────────────────────────────────
function toggleSidebar() {
  const sb = document.getElementById('sidebar');
  const isMobile = window.innerWidth <= 700;
  if (isMobile) {
    sb.classList.toggle('mobile-open');
  } else {
    sb.classList.toggle('collapsed');
    document.getElementById('sidebar-open-btn').style.display =
      sb.classList.contains('collapsed') ? 'flex' : 'none';
  }
}
// close sidebar when tapping outside on mobile
document.addEventListener('click', (e) => {
  const sb = document.getElementById('sidebar');
  if (window.innerWidth <= 700 && sb.classList.contains('mobile-open') &&
      !sb.contains(e.target) && !document.getElementById('sidebar-open-btn').contains(e.target)) {
    sb.classList.remove('mobile-open');
  }
});

// ── THEME ─────────────────────────────────────────────────────
function setTheme(name) {
  document.documentElement.setAttribute('data-theme', name);
  localStorage.setItem('mai_theme', name);
  document.querySelectorAll('.theme-dot').forEach(d => {
    d.classList.toggle('active', d.dataset.theme === name);
  });
}
(function(){
  const t = localStorage.getItem('mai_theme') || 'dark';
  document.documentElement.setAttribute('data-theme', t);
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.theme-dot').forEach(d => {
      d.classList.toggle('active', d.dataset.theme === t);
    });
  });
})();

// ── MARKDOWN ──────────────────────────────────────────────────
marked.setOptions({ breaks: true, gfm: true });
function renderMd(text) {
  try { return marked.parse(text); } catch { return escHtml(text); }
}
function escHtml(t) {
  return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── UTILS ─────────────────────────────────────────────────────
function scrollBottom() {
  const ca = document.getElementById('chat-area');
  ca.scrollTop = ca.scrollHeight;
}

// close modal on overlay click
document.getElementById('settings-modal').addEventListener('click', function(e) {
  if (e.target === this) closeSettings();
});

// ── KEYBOARD ZONE NAVIGATION ──────────────────────────────────
const KB_ZONES = ['input', 'sessions', 'toggles'];
const KB_HINTS = {
  input:    'Shift+Tab · next zone · Enter · send · Shift+Enter · newline · ? · shortcuts',
  sessions: '↑↓ · navigate · Enter · open · Esc · back to input · Shift+Tab · next zone',
  toggles:  '←→ · navigate · Enter · toggle · Esc · back to input · Shift+Tab · next zone',
};

function cycleZone() {
  if (!S.noMouse) return;
  const i = KB_ZONES.indexOf(S.kbZone);
  S.kbZone = KB_ZONES[(i + 1) % KB_ZONES.length];
  activateZone(S.kbZone);
}

function activateZone(zone) {
  S.kbZone = zone;
  updateKbHintBar();
  if (zone === 'input') {
    document.getElementById('chat-input').focus();
  } else if (zone === 'sessions') {
    const sidebar = document.querySelector('.sidebar');
    if (sidebar && !sidebar.classList.contains('collapsed')) { focusSession(0); }
    else { S.kbZone = 'toggles'; activateZone('toggles'); }
  } else if (zone === 'toggles') {
    const btns = document.querySelectorAll('.toggles .toggle-btn');
    if (btns.length) btns[0].focus();
  }
}

function updateKbHintBar() {
  const bar = document.getElementById('kb-hint-bar');
  if (!bar) return;
  const pairs = (KB_HINTS[S.kbZone] || '').split('·');
  let html = '';
  for (let i = 0; i < pairs.length - 1; i += 2) {
    const key = pairs[i].trim(), desc = (pairs[i+1] || '').trim();
    html += `<span><span class="kb-hint-key">${key}</span>${desc}</span>`;
    if (i + 2 < pairs.length - 1) html += `<span style="color:var(--border2)">·</span>`;
  }
  bar.innerHTML = html;
}

// ── PHONE MODE ────────────────────────────────────────────────
function togglePhoneMode() {
  S.phoneMode = !S.phoneMode;
  document.body.classList.toggle('phone-mode', S.phoneMode);
  localStorage.setItem('mai_phone_mode', S.phoneMode);
  const btn = document.getElementById('phone-btn');
  if (btn) btn.classList.toggle('on', S.phoneMode);
  if (S.phoneMode) {
    // Release mic so phone keyboard voice input works without conflict
    stopMic();
    if (S.toggles.stt) { S.toggles.stt = false; localStorage.setItem('mai_stt_on', false); updateToggles(); }
  }
  showToast(S.phoneMode ? '📱 Phone mode on — mic released for phone keyboard' : '🖥️ Desktop mode');
}

function toggleNoMouse() {
  S.noMouse = !S.noMouse;
  document.body.classList.toggle('no-mouse', S.noMouse);
  localStorage.setItem('mai_no_mouse', S.noMouse);
  const btn = document.getElementById('nomouse-btn');
  if (btn) btn.classList.toggle('on', S.noMouse);
  showToast(S.noMouse ? '⌨️ Keyboard mode on' : '🖥️ Mouse mode');
  if (S.noMouse) { S.kbZone = 'input'; activateZone('input'); }
  else { const bar = document.getElementById('kb-hint-bar'); if (bar) bar.innerHTML = ''; }
}

// ── AI MODE (SAFE / PLAN / AUTO) ──────────────────────────────
const AI_MODES = ['SAFE','PLAN','AUTO'];
const AI_MODE_PROMPTS = {
  SAFE: '',
  PLAN: ' When asked to do something, first outline a step-by-step plan and wait for the user to say "go" before proceeding.',
  AUTO: ' Act directly and efficiently. Execute tasks without narrating every step.'
};

function cycleAiMode() {
  const idx = AI_MODES.indexOf(S.aiMode);
  S.aiMode = AI_MODES[(idx + 1) % AI_MODES.length];
  localStorage.setItem('mai_ai_mode', S.aiMode);
  updateAiModeBtn();
  showToast('Mode: ' + S.aiMode);
}

function updateAiModeBtn() {
  const btn = document.getElementById('ai-mode-btn');
  btn.textContent = S.aiMode;
  btn.className = S.aiMode === 'PLAN' ? 'mode-plan' : S.aiMode === 'AUTO' ? 'mode-auto' : '';
  btn.id = 'ai-mode-btn';
}

// ── KEYBOARD HELP ─────────────────────────────────────────────
function showKbHelp() {
  document.getElementById('kb-help').classList.add('open');
}
function hideKbHelp() {
  document.getElementById('kb-help').classList.remove('open');
}

// ── GLOBAL KEYBOARD SHORTCUTS ─────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
    if (e.key === 'Tab' && e.shiftKey) { e.preventDefault(); togglePhoneMode(); return; }
    return;
  }
  if (e.key === '?') { showKbHelp(); return; }
  if (e.key === 'Escape') { hideKbHelp(); if (S.noMouse && S.kbZone !== 'input') { activateZone('input'); } return; }
  if (e.key === 'Tab' && e.shiftKey) { e.preventDefault(); if (S.noMouse) cycleZone(); else togglePhoneMode(); return; }
  if (S.noMouse && S.kbZone === 'toggles' && (e.key === 'ArrowLeft' || e.key === 'ArrowRight')) {
    e.preventDefault();
    const btns = [...document.querySelectorAll('.toggles .toggle-btn')];
    const idx = btns.indexOf(document.activeElement);
    const next = btns[(idx + (e.key === 'ArrowRight' ? 1 : -1) + btns.length) % btns.length];
    if (next) next.focus();
    return;
  }
  if (e.ctrlKey && e.key === 'k' && !e.shiftKey) { e.preventDefault(); cycleAiMode(); return; }
  if (e.ctrlKey && e.shiftKey && e.key === 'K') { e.preventDefault(); toggleNoMouse(); return; }
  if (e.ctrlKey && e.shiftKey && e.key === 'S') { e.preventDefault(); focusSession(0); return; }
  if (e.ctrlKey && e.key === 'n') { e.preventDefault(); newChat(); return; }
  if (e.ctrlKey && e.key === '/') { e.preventDefault(); openSettings(); return; }
  if (e.ctrlKey && e.key === 'm') { e.preventDefault(); micClick(); return; }
});

// ── START ─────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', init);
</script>

<!-- KEYBOARD HELP OVERLAY -->
<div id="kb-help" onclick="hideKbHelp()">
  <div id="kb-help-box" onclick="event.stopPropagation()">
    <h3>⌨️ Keyboard Shortcuts</h3>
    <div style="font-size:11px;color:var(--text3);margin-bottom:10px;text-transform:uppercase;letter-spacing:.05em">Input</div>
    <div class="kb-row"><span class="kb-key">Enter</span><span class="kb-desc">Send message</span></div>
    <div class="kb-row"><span class="kb-key">Shift+Enter</span><span class="kb-desc">New line (no send)</span></div>
    <div class="kb-row"><span class="kb-key">↑ empty input</span><span class="kb-desc">Recall last message</span></div>
    <div class="kb-row"><span class="kb-key">x + Enter</span><span class="kb-desc">Stop streaming response</span></div>
    <div style="font-size:11px;color:var(--text3);margin:10px 0 8px;text-transform:uppercase;letter-spacing:.05em">App</div>
    <div class="kb-row"><span class="kb-key">Ctrl+N</span><span class="kb-desc">New chat</span></div>
    <div class="kb-row"><span class="kb-key">Ctrl+K</span><span class="kb-desc">Cycle mode: SAFE → PLAN → AUTO</span></div>
    <div class="kb-row"><span class="kb-key">Ctrl+M</span><span class="kb-desc">Toggle mic (voice input)</span></div>
    <div class="kb-row"><span class="kb-key">Ctrl+/</span><span class="kb-desc">Open settings</span></div>
    <div style="font-size:11px;color:var(--text3);margin:10px 0 8px;text-transform:uppercase;letter-spacing:.05em">View</div>
    <div class="kb-row"><span class="kb-key">Shift+Tab</span><span class="kb-desc">📱 Phone mode (or cycle zones in ⌨️ mode)</span></div>
    <div class="kb-row"><span class="kb-key">Ctrl+Shift+K</span><span class="kb-desc">⌨️ Toggle keyboard mode</span></div>
    <div class="kb-row"><span class="kb-key">?</span><span class="kb-desc">Show this panel</span></div>
    <div class="kb-row"><span class="kb-key">Esc</span><span class="kb-desc">Close panel / back to input</span></div>
    <div style="font-size:11px;color:var(--text3);margin:10px 0 8px;text-transform:uppercase;letter-spacing:.05em">⌨️ Keyboard Mode Navigation</div>
    <div class="kb-row"><span class="kb-key">Shift+Tab</span><span class="kb-desc">Cycle zones: input → sessions → toggles</span></div>
    <div class="kb-row"><span class="kb-key">↑ ↓</span><span class="kb-desc">Navigate sessions list</span></div>
    <div class="kb-row"><span class="kb-key">← →</span><span class="kb-desc">Navigate header buttons</span></div>
    <div class="kb-row"><span class="kb-key">Enter</span><span class="kb-desc">Open session / activate button</span></div>
    <div class="kb-row"><span class="kb-key">Esc</span><span class="kb-desc">Return to chat input</span></div>
  </div>
</div>
<div id="kb-hint-bar"></div>
</body>
</html>
