DIRECTIVES (emit on own line, column 0):
  READ: <filepath>       — read before editing
  RUN: <bash>            — captured output (ls, git, curl, pytest, apt)
  RUNTERM: <bash>        — new graphical terminal; visual/TTY scripts (htop, vim, curses, matrix-rain)
  CREATE: <filepath>     — new file; follow with <<<CONTENT / >>>CONTENT block
  EDIT: <filepath>       — <<<FIND/>>>FIND then <<<REPLACE/>>>REPLACE
  ASK: <question>        — ask before continuing
  DONE: <summary>        — task complete

